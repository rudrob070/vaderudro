        // Change Cards to Slider in Mobile
        homepage_carousel_init();
        jQuery('.homePg_Row8 .vce-content-slider-arrow').click(function() {
            var indexval = jQuery('.homePg_Row8 .slick-active').attr("data-slick-index");
            indexval = parseInt(indexval) + 1;
            var slider_num = jQuery('.homePg_Row8 .vce-content-slide').not('.slick-cloned').size();
            if (slider_num == indexval) {
                indexval = 0;
            }
            jQuery('.homePg_Row8 .slider-nav-list-item').removeClass('active');
            jQuery('.homePg_Row8 .slider-nav-list-item').filter("[value='" + indexval + "']").addClass('active');
        });

        jQuery('.slider-nav-list-item').click(function() {
            jQuery('.slider-nav-list-item').removeClass('active');
            jQuery(this).addClass('active');
            var index_number = jQuery(this).val();
            var mul = index_number + 1;
            var win_width = jQuery(window).width();
            var trans_num = win_width * mul;
            jQuery(".homePg_Row8 .vce-content-slide").removeClass("slick-current slick-active");
            jQuery(".homePg_Row8 .vce-content-slide").attr("aria-hidden", "true");
            jQuery(".homePg_Row8 .vce-content-slide").attr("tabindex", "-1");
            jQuery('.homePg_Row8 .vce-content-slide[data-slick-index=' + index_number + ']').addClass("slick-current slick-active");
            jQuery('.homePg_Row8 .vce-content-slide[data-slick-index=' + index_number + ']').attr("aria-hidden", "false");
            jQuery('.homePg_Row8 .vce-content-slide[data-slick-index=' + index_number + ']').removeAttr("tabindex");
            jQuery(".homePg_Row8 .slick-track").css({
                'transform': 'translate3d(-' + trans_num + 'px, 0px, 0px)'
            })
        });
        if (window.matchMedia("(max-width: 1024px)").matches) {
            area_carousel_init();
            // 			jQuery(".mswipe-slider .vce-content-slider-slides").slider();
            // 			jQuery(".gall_slider").draggable({axis: "x", revert: true});

            jQuery('.vce-video-popup-controls-wrapper').attr('data-vcv-video-player-controls-active', 'true');
        }
    });
    jQuery(window).on('resize', function() {
        
            area_carousel_init();
            // 			jQuery(".mswipe-slider .vce-content-slider-slides").slider();
            // 			jQuery(".gall_slider").draggable({axis: "x", revert: true});
        if (window.matchMedia("(max-width: 1024px)").matches) {
            jQuery('.vce-video-popup-controls-wrapper').attr('data-vcv-video-player-controls-active', 'true');
        }
    });

    function area_carousel_init() {

        if(jQuery(window).width() < 1024){
            jQuery('.homePg_Row2 .vce-row-content').addClass('owl-carousel owl-theme');
            jQuery('.Inner_Page_Row .vce-row-content').addClass('owl-carousel owl-theme');

            jQuery('.homePg_Row2 .vce-row-content').owlCarousel({
                loop: false,
                margin: 40,
                nav: true,
                items: 1,
                singleItem: true,
                dots: false,
                responsive: {
                    0: {
                        stagePadding: 0,
                    },
                    380: {
                        stagePadding: 20,
                    }
                }
            });
            jQuery('.Inner_Page_Row .vce-row-content').owlCarousel({
                loop: false,
                margin: 40,
                nav: true,
                items: 1,
                singleItem: true,
                dots: false,
                responsive: {
                    0: {
                        stagePadding: 0,
                    },
                    380: {
                        stagePadding: 20,
                    }
                }
            });

        }
        else{
            jQuery('.homePg_Row2 .vce-row-content.owl-carousel').trigger('destroy.owl.carousel');

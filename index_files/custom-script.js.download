        jQuery(this).replaceWith('<h3 class="title">'+innerTxt+'</h3>')
    });
    /*revolution slider focus state*/
    jQuery('.tparrows').attr('tabindex','0');
    /*cover for if lazy load is on*/
    jQuery('.vce-slider-revolution').on('revolution.slide.onloaded', function(){
        jQuery('.tparrows').attr('tabindex','0');
        jQuery('rs-arrow.tp-rightarrow, rs-arrow.tp-leftarrow').on('keydown', function(e){
            if(e.keyCode == 13){
                jQuery(this).click();
            }
        });

    });
    
    /* hide alert focus if not showing on page */
    jQuery('.homePg_Alert.visually-hidden a').attr('tabindex', '-1');

    /* search focus */
    jQuery('.searchWrapper .vce-popup-root').after(jQuery('.vce-popup-root-close-button'));

     jQuery(document).on('keydown', function(e){
         if(jQuery('.searchWrapper.vcv-popup-container--visible').length && e.keyCode==9){
            if(jQuery(e.target).is('.vce-popup-root-close-button') && !e.shiftKey){
                e.preventDefault();
                jQuery('.gsc-input').focus();
            }
            else if(jQuery(e.target).is('.gsc-input') && e.shiftKey){
                e.preventDefault();
                jQuery('.vce-popup-root-close-button').focus();
            }
        }

     });

    /*search focus*/
     jQuery('header .fa-search, header .searchCol a.vce-single-image-inner').on('click keyup', function(e){
        if(e.type == 'click' || e.keyCode === '13'){
            var i = 1;
            var gscExist = setInterval(function() {
                if(i>30){
                    clearInterval(gscExist);
                }
                if(jQuery('.gsc-input').length)
                {
                    jQuery('.gsc-search-box .gsc-input-box .gsc-input').focus();
                    clearInterval(gscExist);
                }
                else{
                    i++;
                }
     
             }, 10);
            
        }
    });
    /*feature video keyboard */
    jQuery('.vce-video-popup-fullscreen-play .vce-features--icon').on('keyup', function(e){
        if(e.keyCode == 13){
            jQuery(this).click();
        }
    });
    /* search suggestions bold tags */
    jQuery('.gsc-input-box input').on('keyup', function(e){
        setTimeout(function(){
            jQuery('.gsc-completion-container b').each(
                function(e){
                    jQuery(this).replaceWith('<strong>'+jQuery(this).text()+'</strong>');
                }
            );
        },50);
    });

    /* aria label on hidden button --  hero button */
    jQuery('.hero__text .vce-button').attr('aria-label', jQuery('.hero__text .vce-button').text());
    /*remove tabbing on overarching anchor for three column image and links*/
    jQuery('.homePg_Row2_Col > a').attr('tabindex','-1');
    /*tabbing on tertiary nav without links*/
    
    jQuery('.topMenu_Wrapper .menu-topbar-menu-container .sub-menu-toggle').on('keyup', function(e){
       // jQuery(this).click();
        jQuery('.topMenu_Wrapper .menu-topbar-menu-container .menu-item').removeClass('opened');
        jQuery(this).parent().addClass('opened');
        
    });

    /* gallery slider */
    jQuery('.vce-content-slider-arrow, .vce-content-slider-inner .slick-active figure').attr('tabindex','0');
    jQuery('.vce-content-slider-inner .vce-content-slider-arrow, .vce-content-slider-inner .slick-active figure ').on('keyup', function(e){
        if(e.keyCode==13){
            jQuery(this).click();
            jQuery('.vce-content-slider-inner .slick-slide figure').attr('tabindex','-1');
            jQuery('.vce-content-slider-inner .slick-active figure').attr('tabindex','0');
        }
    });
    
    /*impact showcase keyboard*/
    jQuery('.impactTabs .vce-tabs-with-slide-tab-title').on('keydown', function(e){
        if(e.keyCode == 9){
            if(!e.shiftKey){
                if(jQuery(e.target).parent().is('.vce-tabs-with-slide-tab[data-vcv-active=true]')){
                    if(jQuery('.vce-tabs-with-slide-panel[data-vcv-active=true] .vce-tabs-with-slide-panel-body').find('a').length){
                        e.preventDefault();
                        jQuery('.vce-tabs-with-slide-panel[data-vcv-active=true] .vce-tabs-with-slide-panel-body').find('a').first().focus();
                    }
                } else if(!jQuery(e.target).parent().is('.vce-tabs-with-slide-tab[data-vcv-active=true]') && jQuery(e.target).parent().is('.vce-tabs-with-slide-tab:last-of-type')){
                     jQuery('.impactTabs').parent().next().find('a').first().focus();
                 }
            }else{
                //if the one you're clicking on is active
                if(jQuery(e.target).parent().prev().is('.vce-tabs-with-slide-tab[data-vcv-active=true]')){
                    e.preventDefault();
                    jQuery('.vce-tabs-with-slide-panel[data-vcv-active=true] .vce-tabs-with-slide-panel-body').find('a').last().focus();
                }
            }
        }
    });

    jQuery('.impactTabs .vce-tabs-with-slide-panel-body a').on('keydown', function(e){
        if(e.keyCode == 9){
            //tabbing backward and it's the first one
            if(jQuery(e.target).is('.vce-tabs-with-slide-panel-body a:first-of-type') && e.shiftKey){
                jQuery('.vce-tabs-with-slide-tab[data-vcv-active=true]').next('.vce-tabs-with-slide-tab').find('a').focus();
            }
            else if(jQuery(e.target).is('.vce-tabs-with-slide-panel-body a:last-of-type') && !e.shiftKey){
                if(!jQuery('.vce-tabs-with-slide-tab[data-vcv-active=true]').is('.vce-tabs-with-slide-tab:last-of-type')){
                    jQuery('.vce-tabs-with-slide-tab[data-vcv-active=true]').find('a').focus();
                }
            }
        }
    });
    /* end impact showcase keyboard*/

    jQuery('.skipToContent_Btn .vce-button').on('keydown', function(e){
        
        if(e.keyCode == 13){
            e.preventDefault();
            e.stopPropagation();
            jQuery('#content').find('a, button, [tabindex=0]').first().focus();
        }
    });

    jQuery('.hero__text a.vce-button').on('focus keyup', function(e){
       jQuery('.hero__text').addClass('hero_text_hover');
    });
    jQuery('.hero__text a.vce-button').on('keydown', function(e){
        jQuery('.hero__text').removeClass('hero_text_hover');
    });
    jQuery('a').on('keyup', function(e){
        //if not in the top menu
        //OR
        // if the achor parent is menu item but not in sub menu
        if(!jQuery(this).parents('.topMenu_Wrapper').length ||
         (!jQuery(this).parents('.sub-menu').length &&
          !jQuery(this).parent().children('.sub-menu-toggle').length)){
            jQuery('.topMenu_Wrapper .menu-topbar-menu-container .menu-item').removeClass('opened');
        }
    });
    jQuery('body').on('click',function(){
        jQuery('.topMenu_Wrapper .menu-topbar-menu-container .menu-item').removeClass('opened');
    });

    jQuery('.newSubmenu .sub-menu-toggle').removeAttr('onclick');
    jQuery('.mega-menu-item-has-children .mega-indicator, .newSubmenu .menu-item-has-children').on('click', function(e){
       
        console.log('inside click');
        if(!jQuery(this).hasClass('opened-item') && jQuery(window).width() < 1024 && !jQuery(this).is(jQuery('.mega-indicator'))){
            console.log('inside if statement');
           e.preventDefault();
            jQuery('.mega-menu-item-has-children, .menu-item-has-children').removeClass('opened-item');
            jQuery('.mega-menu-item-has-children').removeClass('mega-toggle-on');
            jQuery('.newSubmenu .menu-item-has-children .sub-menu').hide();
            if(jQuery(this).is(jQuery('.mega-menu-item-has-children > a')))
                jQuery(this).parents('.mega-menu-item-has-children').addClass('mega-toggle-on');
            else if(jQuery(this).is('.newSubmenu .menu-item-has-children')){
                jQuery(this).find('.sub-menu').show();
                jQuery(this).addClass('opened-item');
            }
            else
                jQuery(this).addClass('mega-toggle-on');
            jQuery(this).addClass('opened-item');
        }
        else{
            console.log('inside else');
            jQuery('.menu-item-has-children').removeClass('opened-item');
            jQuery(this).find('.sub-menu').hide();
        }
    });


});
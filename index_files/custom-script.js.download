    function displayUFAlert() {
        var alertContainer = document.getElementsByClassName("alertBoxWrapper")[0];

        if (!window.location.href.includes('wp-admin')) {
            if (alertContainer) {
                fetch('https://ufalert.ufl.edu/wp-json/wp/v2/posts?category=22&per_page=1')
                    .then(response => response.json())
                    .then(function(json) {
                        var lastAlert = json[0];
                        if (lastAlert.title.rendered.toLowerCase().indexOf('timely warning') > -1) {
                            var timeThreshold = Math.floor((Date.now()) - 9000000); // 2.5 hours in milliseconds
                        } else {
                            var timeThreshold = Math.floor((Date.now()) - 5400000); // 1.5 hours in milliseconds
                        }
                        var alertDate = new Date(lastAlert.date_gmt + 'Z');
                        var alertTime = alertDate.getTime();
                        if (alertTime > timeThreshold) {
                            if (lastAlert.title.rendered.toLowerCase().indexOf('active shooter') > -1) {
                                var alertPopUp = document.getElementsByClassName("generic_popup_wrap")[0];

                                var popUpHeading = alertPopUp.querySelector("h2");
                                popUpHeading.innerHTML = lastAlert.title.rendered;
                                popUpHeading.classList.add("ufalert-popup-header");

                                var popUpparagraph = alertPopUp.querySelector("p");
                                popUpparagraph.innerHTML = lastAlert.excerpt.rndered.replace(/(<([^>]+)>)/gi, "") + ' <a href="' + lastAlert.link + '></a>';
                                popUpparagraph.classList.add("ufalert-popup-teaser");

                                var alertLink = document.createElement("a");
                                alertLink.href = lastAlert.link;
                                alertLink.innerHTML = "Read the Alert";
                                popUpparagraph.appendChild(alertLink);

                                alertPopUp.classList.remove('visually-hidden');
                            }
                            var heading = alertContainer.querySelector("h2");
                            heading.innerHTML = lastAlert.title.rendered;
                            heading.classList.add("ufalert-header");

                            var paragraph = alertContainer.querySelector("p");
                            paragraph.innerHTML = lastAlert.excerpt.rendered;
                            paragraph.classList.add("ufalert-teaser");

                            var wrapper = document.createElement('a');
                            wrapper.setAttribute("href", lastAlert.link);

                            var parent = alertContainer.parentNode;
                            parent.replaceChild(wrapper, alertContainer);
                            wrapper.appendChild(alertContainer);

                            var row = document.getElementsByClassName("homePg_Alert")[0];
                            row.classList.remove("visually-hidden");

                            if (alertContainer.parentElement.getAttribute("href").indexOf('ufalert.ufl.edu') > -1) {
                                var options = {
                                    key: '|>g<$=z_V(K7=`>RM=;{u|6&0Z2MEz6ZO?WDd=-$R>_H,1h-fR9#+fA,:leE}+`[',
                                    message: heading.innerHTML,
                                    date_gmt: lastAlert.date_gmt,
                                    slug: lastAlert.slug
                                };
                                fetch('https://assets.webadmin.ufl.edu/alerts/homepage-alert-verify.php', {
                                    method: 'post',
                                    body: JSON.stringify(options)
                                })
                            }
                        }
                    });
            }
        }
    }
    displayUFAlert();

    //header class for alert start
    jQuery(document).ready(function() {
        if (jQuery("#alert-message").length) {
            jQuery(".vcv-header").addClass('header-with-alert');
            jQuery(".vcv-header").removeClass('header-without-alert');
        } else {
            jQuery(".vcv-header").addClass('header-without-alert');
        }

        if (jQuery(".vcv-header .vce-row-container .newsPgHeader").length) {
            jQuery(".vcv-header").addClass('header-news');
        }
        //header class for alert End


        /*Start Global Footer*/
        if (jQuery("#footerTopBorder").length > 0) {
            init_orange_bar_footer();
            jQuery(window).scroll(function() {
               
                init_orange_bar_footer();
            });
        }

        function init_orange_bar_footer() {
            var footer_distance = jQuery('.vcv-footer').offset().top;
            var footer_height = jQuery('.vcv-footer').height();
            var scroll_current_distance = jQuery(window).scrollTop() + footer_height;
            var height_video = scroll_current_distance - footer_distance;
            var scrolled = (height_video * 100) / footer_height;
            if (height_video < footer_height && height_video > 0) {
                document.getElementById("footerTopBorder").style.width = scrolled + "%";
            }
            if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight) {
                document.getElementById("footerTopBorder").style.width = 100 + "%";
            }
            if (window.scrollY === 0) {
                document.getElementById("footerTopBorder").style.width = 0 + "%";
            }
        }
        /*End Global Footer*/

        /*** will there be multiple on a page? could cause accessibility issues */
        jQuery('article').find('.entry-content').attr('id', 'content');
        jQuery(".hoverImage").hover(function() {
       
            jQuery('.hero__text').addClass('hero_text_hover');
        }, function() {
            jQuery('.hero__text').removeClass('hero_text_hover');
        });

        // Cookie Check to stop showing Popup
        function getCookie(cookiename) {
            if (typeof(cookiename) == 'string' && cookiename != '') {
                const COOKIES = document.cookie.split(';');
                for (i = 0; i < COOKIES.length; i++) {
                    if (COOKIES[i].trim().startsWith(cookiename)) {
                        return COOKIES[i].split('=')[1];
                    }
                }
            }
            return null;
        }
        const COOKIE_EXAMPLE = getCookie('alertMessage');
        /*alert hide start*/
        if (COOKIE_EXAMPLE == 'true') {

            jQuery('#alert-message').hide();
            jQuery('.home header.vcv-header .vce-row.vce-element--has-background.vce-row--col-gap-5.headerRow').removeAttr('style');
            jQuery(".vcv-header").removeClass('header-with-alert');
            jQuery(".vcv-header").addClass('header-without-alert');
            jQuery(window).on('scroll', function() {
                if (jQuery(window).scrollTop() > 0) {
                    jQuery("header.vcv-header").addClass("hide_header");
                } else {
                    jQuery("header.vcv-header").removeClass("hide_header");
                }
            });
        } else {
            jQuery('#alert-message').show();
        }
        jQuery('.closeBtn').click(function() {
            document.cookie = "alertMessage=true; max-age=300; path=/";
            jQuery('#alert-message').hide();
            jQuery('.home header.vcv-header .vce-row.vce-element--has-background.vce-row--col-gap-5.headerRow').removeAttr('style');
            jQuery(".vcv-header").removeClass('header-with-alert');
            jQuery(".vcv-header").addClass('header-without-alert');
            jQuery(window).on('scroll', function() {
                if (jQuery(window).scrollTop() > 0) {
                    jQuery("header.vcv-header").addClass("hide_header");
                } else {
                    jQuery("header.vcv-header").removeClass("hide_header");
                }
            });
        });
        /* end alert hide */

        // .vce-features--icon
        jQuery('.vce-video-popup-fullscreen-pause .vce-features--icon').on('click keyup', function(e) {
            if(e.type == 'click' || e.keyCode == 13){
                e.stopPropagation();
                var video_class = jQuery(this).closest('.vce-video-popup-video-block').find('.vce-video-popup-video');
                
                if (video_class.get(0).paused == false) {
                    video_class.get(0).pause();
                    jQuery(this).find('.fa-pause').addClass('fa-play').removeClass('fa-pause');
                } else {
                    video_class.get(0).play();
                    jQuery(this).find('.fa-play').addClass('fa-pause').removeClass('fa-play');
                }
            }
           
        });

    });

    jQuery(document).ready(function() {

        //open first tab by default
        
        jQuery('.vce-tabs-with-slide-tab').on('click', function(e) {
           
            if (jQuery(this).attr('data-vcv-active') == 'true') {
                jQuery(this).attr("data-vcv-active", 'false');

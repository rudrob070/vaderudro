   //***may be removed at later date

    /*livewhale*/
    jQuery(document).ready(function() {
        var i = 1;
       var livewhaleexist = setInterval(function() {

            if(i>30){
                clearInterval(livewhaleexist);
            }

           if(jQuery('.lwcw .upcoming-events-item').length){
               clearInterval(livewhaleexist);
              /*fixes LiveWhale out of order headings*/
                jQuery('.lwcw.slick .upcoming-events-item').each(function(){
                    var innerTxt = jQuery('h4', this).html();
                    jQuery('h4', this).replaceWith('<h3 class="h4">'+innerTxt+'</h3>')
                });
                jQuery('.lwcw').slick({
                    prevArrow: '<button class="slick-prev" aria-label="Previous" type="button"></button>',
                    nextArrow: '<button class="slick-next" aria-label="Next" type="button"></button>',
                    arrows: true,
                    slidesToShow: 4,
                    slidesToScroll: 1,
                    responsive: [{
                        breakpoint: 1400,
                        settings: {
                            slidesToShow: 3,
                            slidesToScroll: 1,
                            arrows: true,
                        }
                    },    
                    {
                        breakpoint: 1024,
                        settings: {
                            slidesToShow: 2,
                            slidesToScroll: 1,
                            arrows: true,
                        }
                    }, {
                        breakpoint: 811,
                        settings: {
                            slidesToShow: 1,
                            slidesToScroll: 1,
                            arrows: true,
                        }
                    }, {
                        breakpoint: 481,
                        settings: {
                            slidesToShow: 1,
                            slidesToScroll: 1,
                            arrows: true,
                            centerMode: false,
                            swipeToSlide: true,


                        }
                    }]

                });
                jQuery('.lwcw .slick-list').before(jQuery('.lwcw .slick-prev'));
                jQuery('.lwcw .slick-slide a').attr('tabindex', '-1');
                jQuery('.lwcw .slick-list').removeAttr('tabindex');
                jQuery('.lwcw .slick-active a').attr('tabindex', '0');
                /* Livewhale slick slider tabbing */
               
                jQuery('.lwcw .slick-slide a').on('keyup', function(e){
                    if(e.keyCode == 9){
                        jQuery('.lwcw .slick-slide').removeClass('hovered');
                        jQuery(this).parent().parent().addClass('hovered');
                    }
                });
                jQuery('.slick-next, .slick-prev').on('click keyup', function(e){
                    if(e.keyCode == 13){
                        jQuery('.lwcw .slick-slide').removeClass('hovered');
                        jQuery('.lwcw .slick-slide a').attr('tabindex', '-1');
                        jQuery('.lwcw .slick-active a').attr('tabindex', '0');
                    }
                    else if(e.keyCode == 9){
                        jQuery('.lwcw .slick-slide').removeClass('hovered');
                    }
                   
                });
            }
            else{
                i++;
            }

        }, 100);
    });
    /*end livewhale*/

    /*scroll header sticky*/
    jQuery(document).ready(function() {
      
        var lastScrollTop = 0;
        jQuery(window).scroll(function(event){
           var st = jQuery(this).scrollTop();
           if (st > lastScrollTop){
               jQuery('header').addClass('scrolling_down');
               jQuery('header').removeClass('scrolling_up');
           } else {
               jQuery('header').addClass('scrolling_up');
               jQuery('header').removeClass('scrolling_down');
           }
           lastScrollTop = st;
        });
    });
    /*end scroll header sticky*/


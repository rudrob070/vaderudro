    function triggerMenuUpdates(){
        menuUpdates2();
        if(window.matchMedia("(max-width: 1023px)").matches){
			jQuery('.newSubmenu .menu-item-has-children').each(function() {
				var theclick = 0;
// 				jQuery(this).find('a').click(function(e){
				 jQuery(this).find('a:not([href]').click(function(e){
					if(theclick == 0){
						e.preventDefault();
						jQuery(this).parent('li').find('.sub-menu').show();
						theclick = theclick + 1;					
					}
                    else{
                        jQuery(this).parent('li').find('.sub-menu').hide();
                        theclick = 0;
                    }				
				});
			});			
		}else{
            jQuery('.menu-topbar-menu-container .menu-item-has-children').each(function() {

                jQuery(this).find('.sub-menu').show();
            });
        }
    }
    function menuUpdates2(){
          /*Start Global Header*/
          if (window.matchMedia("(max-width: 1023px)").matches) {
            var mobileHeaderH = jQuery('.headerRow > .vce-row-content').height();
            jQuery('.mega-menu-toggle').css('height', mobileHeaderH + 20 + 'px');
            if(!jQuery('.mega-menu-wrap li.newSubmenu .topMenu_Wrapper ul.menu').length){
                jQuery(".topMenu_Wrapper ul.menu").wrapAll('<li class="newSubmenu" />');
                jQuery(".main_Navigation ul.menu").wrapAll('<li class="newSubmenu" />');
                jQuery(".newSubmenu").appendTo(jQuery('.mega-menu.max-mega-menu.mega-menu-horizontal'));
            }
        }
        else{
            if(!jQuery('.topRight_Menu .topMenu_Wrapper ul.menu').length){
                jQuery('.newSubmenu > ul.menu').appendTo(jQuery('.menu-topbar-menu-container'));
                jQuery('li.newSubmenu').remove();
            }
        }
        /*End Global Header*/
    }


